# Kalshi credentials (required for live trading)
KALSHI_API_KEY=your-kalshi-api-key-id
KALSHI_PRIVATE_KEY_PATH=C:\path\to\kalshi-private-key.pem
# Or inline PEM (use \n for newlines if storing on one line)
# KALSHI_PRIVATE_KEY_PEM=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# Optional data providers
GLASSNODE_API_KEY=
CRYPTOQUANT_API_KEY=

# Alerts
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK=

# Bot behavior
SIMULATION_MODE=true
STRATEGY_MODE=15min
EDGE_THRESHOLD=0.15
LOOP_INTERVAL_SECONDS=20
MAX_CONTRACTS=5
LOG_LEVEL=INFO

# API
KALSHI_API_BASE=https://external-api.kalshi.com/trade-api/v2
REQUEST_TIMEOUT=15
CCXT_EXCHANGE=coinbase
LOG_FILE=kalshi_btc_log.csv
BACKTEST_FILE=backtest_results.csv